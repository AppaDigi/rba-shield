// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  username      String    @unique
  name          String?
  passwordHash  String?
  bio           String?
  avatar        String? // base64 data URL or external URL
  location      String?
  xp            Int       @default(0)
  cigarsLogged  Int       @default(0)
  reviewCount   Int       @default(0)
  tradeCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Social graph
  following        Follow[]        @relation("Follower")
  followers        Follow[]        @relation("Following")
  sentRequests     FriendRequest[] @relation("Sender")
  receivedRequests FriendRequest[] @relation("Receiver")

  // Feed
  posts    Post[]
  likes    Like[]
  comments Comment[]

  // Live
  liveMessages LiveMessage[]
  auctionBids  AuctionBid[]

  // Exchange
  humidorItems    HumidorItem[]
  swapListings    SwapListing[]
  tradeOffers     TradeOffer[]
  givenRatings    TradeRating[] @relation("Rater")
  receivedRatings TradeRating[] @relation("RatedUser")

  // Messages
  conversations ConversationParticipant[]
  sentMessages  DirectMessage[]

  // Notifications
  notifications Notification[]

  // Societies
  createdSocieties   Society[]       @relation("SocietyCreator")
  societyMemberships SocietyMember[]

  // Stories
  stories Story[]
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  content   String
  mediaUrls String? // JSON-encoded string[]
  societyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  society  Society?  @relation(fields: [societyId], references: [id], onDelete: SetNull)
  likes    Like[]
  comments Comment[]
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ─── Live Streaming & Auctions ────────────────────────────────────────────────

model LiveEvent {
  id            String    @id @default(cuid())
  title         String
  description   String?
  muxStreamId   String?
  muxPlaybackId String?
  youtubeId     String?
  status        String    @default("SCHEDULED") // SCHEDULED | LIVE | ENDED
  viewerCount   Int       @default(0)
  hostName      String?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())

  messages LiveMessage[]
  items    AuctionItem[]
}

model LiveMessage {
  id        String   @id @default(cuid())
  eventId   String
  userId    String?
  guestName String?
  content   String
  type      String   @default("CHAT") // CHAT | SYSTEM
  createdAt DateTime @default(now())

  event LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AuctionItem {
  id                String   @id @default(cuid())
  eventId           String
  title             String
  description       String?
  imageUrl          String?
  startingBid       Int      @default(0)
  currentBid        Int      @default(0)
  currentLeaderName String?
  status            String   @default("UPCOMING") // UPCOMING | ACTIVE | SOLD | PASSED
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())

  event LiveEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bids  AuctionBid[]
}

model AuctionBid {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  amount    Int
  createdAt DateTime @default(now())

  item AuctionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── The Exchange (Swaps) ─────────────────────────────────────────────────────

model HumidorItem {
  id        String   @id @default(cuid())
  userId    String
  name      String
  brand     String?
  size      String?
  wrapper   String?
  origin    String?
  quantity  Int      @default(1)
  notes     String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  swapListings SwapListing[]
}

model SwapListing {
  id              String   @id @default(cuid())
  authorId        String
  humidorItemId   String?
  offeringName    String
  offeringImage   String?
  wantDescription String
  message         String?
  status          String   @default("OPEN") // OPEN | IN_NEGOTIATION | COMPLETED | CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  humidorItem HumidorItem?  @relation(fields: [humidorItemId], references: [id], onDelete: SetNull)
  offers      TradeOffer[]
  ratings     TradeRating[]
}

model TradeOffer {
  id           String   @id @default(cuid())
  listingId    String
  offererId    String
  offeringName String
  message      String?
  status       String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing SwapListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  offerer User        @relation(fields: [offererId], references: [id], onDelete: Cascade)
}

model TradeRating {
  id          String   @id @default(cuid())
  listingId   String
  raterId     String
  ratedUserId String
  score       Int
  comment     String?
  createdAt   DateTime @default(now())

  listing   SwapListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  rater     User        @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  ratedUser User        @relation("RatedUser", fields: [ratedUserId], references: [id], onDelete: Cascade)

  @@unique([listingId, raterId])
}

// ─── Direct Messages ─────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model DirectMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String // FOLLOW | LIKE | COMMENT | TRADE_OFFER | TRADE_ACCEPTED
  actorName   String?
  actorAvatar String?
  body        String
  entityUrl   String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Societies ────────────────────────────────────────────────────────────────

model Society {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  category    String   @default("Social")
  createdAt   DateTime @default(now())
  creatorId   String

  creator User            @relation("SocietyCreator", fields: [creatorId], references: [id])
  members SocietyMember[]
  posts   Post[]
}

model SocietyMember {
  societyId String
  userId    String
  role      String   @default("MEMBER") // MEMBER | MOD | ADMIN
  joinedAt  DateTime @default(now())

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([societyId, userId])
}

// ─── Stories ─────────────────────────────────────────────────────────────────

model Story {
  id        String   @id @default(cuid())
  authorId  String
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ─── Knowledge Base ───────────────────────────────────────────────────────────

model Article {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  excerpt    String?
  content    String
  category   String // REGION | SHAPE | AGING | ETIQUETTE | BRAND | BLEND
  coverImage String?
  authorName String?
  published  Boolean  @default(true)
  readTime   Int      @default(5)
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
