# Supabase transaction pooler (serverless/runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<pooler-host>:6543/postgres?pgbouncer=true&connection_limit=1"
# Supabase session pooler (Prisma migrate deploy)
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<pooler-host>:5432/postgres?connect_timeout=30"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
OPENAI_API_KEY=""
OPENAI_CIGAR_IDENTIFY_MODEL="gpt-4.1-mini"
OPENAI_CIGAR_SEARCH_MODEL="gpt-5"
NEXT_PUBLIC_SUPABASE_URL="https://mnxityqgergzjvoxcwzn.supabase.co"
